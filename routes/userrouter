from fastapi import APIRouter, HTTPException
from models.user import UserCreate, UserResponse, UserInDB
from datetime import datetime

router = APIRouter(prefix="/users", tags=["users"])

# In-memory storage
users_db: dict[int, UserInDB] = {}
user_id_counter = 1

@router.post("/register", response_model=UserResponse)
async def register_user(user: UserCreate):
    """Create a new user account"""
    global user_id_counter
    
    # Check if user exists
    for existing_user in users_db.values():
        if existing_user.username == user.username:
            raise HTTPException(status_code=400, detail="Username already taken")
        if existing_user.email == user.email:
            raise HTTPException(status_code=400, detail="Email already registered")
    
    new_user = UserInDB(
        id=user_id_counter,
        username=user.username,
        email=user.email,
        bio=user.bio or "",
        profile_picture_url=user.profile_picture_url or "",
        password_hash="hashed_password_placeholder",
        followers_count=0,
        following_count=0,
        created_at=datetime.now(),
        followers=[],
        following=[],
    )
    
    users_db[user_id_counter] = new_user
    user_id_counter += 1
    
    return UserResponse(**new_user.model_dump(exclude={"password_hash", "followers", "following"}))

@router.get("/profile/{user_id}", response_model=UserResponse)
async def get_user_profile(user_id: int):
    """Get user profile by ID"""
    if user_id not in users_db:
        raise HTTPException(status_code=404, detail="User not found")
    
    user = users_db[user_id]
    return UserResponse(**user.model_dump(exclude={"password_hash", "followers", "following"}))

@router.post("/follow/{user_id}")
async def follow_user(current_user_id: int, user_id: int):
    """Follow a user"""
    if current_user_id not in users_db:
        raise HTTPException(status_code=404, detail="Current user not found")
    if user_id not in users_db:
        raise HTTPException(status_code=404, detail="Target user not found")
    
    if current_user_id == user_id:
        raise HTTPException(status_code=400, detail="Cannot follow yourself")
    
    current_user = users_db[current_user_id]
    target_user = users_db[user_id]
    
    if user_id not in current_user.following:
        current_user.following.append(user_id)
        current_user.following_count += 1
    
    if current_user_id not in target_user.followers:
        target_user.followers.append(current_user_id)
        target_user.followers_count += 1
    
    return {"status": "followed", "following_count": current_user.following_count}

@router.post("/unfollow/{user_id}")
async def unfollow_user(current_user_id: int, user_id: int):
    """Unfollow a user"""
    if current_user_id not in users_db:
        raise HTTPException(status_code=404, detail="Current user not found")
    if user_id not in users_db:
        raise HTTPException(status_code=404, detail="Target user not found")
    
    current_user = users_db[current_user_id]
    target_user = users_db[user_id]
    
    if user_id in current_user.following:
        current_user.following.remove(user_id)
        current_user.following_count -= 1
    
    if current_user_id in target_user.followers:
        target_user.followers.remove(current_user_id)
        target_user.followers_count -= 1
    
    return {"status": "unfollowed", "following_count": current_user.following_count}