from fastapi import APIRouter, HTTPException
from models.chat import MessageCreate, MessageResponse, MessageInDB, ConversationResponse
from ai.intent import detect_risk_level, is_suspicious_pattern
from datetime import datetime
from collections import defaultdict

router = APIRouter(prefix="/chat", tags=["chat"])

# In-memory storage
messages_db: dict[int, MessageInDB] = {}
message_id_counter = 1
conversations: dict[tuple, list[int]] = defaultdict(list)  # (user1, user2) -> [message_ids]

@router.post("/send")
async def send_message(user_id: int, message: MessageCreate):
    """
    Send direct message with risk detection.
    
    AI Safety Layer 2: Chat Risk Analyzer
    - Analyzes message for risky content before sending
    - If high risk, shows warning banner
    - Returns risk level and warning if detected
    """
    global message_id_counter
    
    if message.recipient_id == user_id:
        raise HTTPException(status_code=400, detail="Cannot message yourself")
    
    # AI SAFETY CHECK: Risk Detection
    risk_analysis = detect_risk_level(message.text)
    suspicious = is_suspicious_pattern(message.text)
    
    if suspicious:
        risk_analysis["risk_level"] = "high"
        risk_analysis["warning"] = "⚠️ Suspicious pattern detected. Be cautious with this message."
    
    new_message = MessageInDB(
        id=message_id_counter,
        sender_id=user_id,
        recipient_id=message.recipient_id,
        text=message.text,
        risk_level=risk_analysis["risk_level"],
        warning=risk_analysis["warning"],
        created_at=datetime.now(),
    )
    
    messages_db[message_id_counter] = new_message
    message_id_counter += 1
    
    # Store in conversation
    conv_key = tuple(sorted([user_id, message.recipient_id]))
    conversations[conv_key].append(message_id_counter - 1)
    
    return {
        "message": "sent",
        "message_id": new_message.id,
        "risk": risk_analysis["risk_level"],
        "warning": risk_analysis["warning"],
    }

@router.get("/conversation/{user_id}/{other_user_id}", response_model=ConversationResponse)
async def get_conversation(user_id: int, other_user_id: int):
    """Get conversation history between two users"""
    conv_key = tuple(sorted([user_id, other_user_id]))
    
    if conv_key not in conversations:
        return ConversationResponse(
            messages=[],
            other_user_id=other_user_id,
            unread_count=0,
        )
    
    message_ids = conversations[conv_key]
    messages = [
        MessageResponse(**messages_db[mid].model_dump())
        for mid in message_ids
        if mid in messages_db
    ]
    
    return ConversationResponse(
        messages=messages,
        other_user_id=other_user_id,
        unread_count=0,  # Simplified
    )

@router.get("/conversations/{user_id}")
async def get_all_conversations(user_id: int):
    """Get all conversations for a user"""
    user_conversations = []
    
    for conv_key, message_ids in conversations.items():
        if user_id in conv_key:
            other_user_id = conv_key[0] if conv_key[1] == user_id else conv_key[1]
            latest_message_id = message_ids[-1] if message_ids else None
            
            if latest_message_id and latest_message_id in messages_db:
                latest_message = messages_db[latest_message_id]
                user_conversations.append({
                    "other_user_id": other_user_id,
                    "last_message": latest_message.text,
                    "last_message_time": latest_message.created_at,
                    "message_count": len(message_ids),
                })
    
    return {"conversations": user_conversations}